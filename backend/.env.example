NODE_ENV=development
PORT=3000
# PostgreSQL connection string. Matches the dev docker-compose credentials.
# In production this points at the shared AusTV Finance instance (dedicated db/user).
DATABASE_URL=postgresql://austv_sales:austv_sales_dev@localhost:5433/austv_sales

# --- Discord OAuth2 (dashboard login, restricted to two users) ---
# Create an application at https://discord.com/developers/applications and copy
# the OAuth2 client id/secret. Add the callback URL below to the app's redirects.
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Public callback URL. In production: https://sales.austv.net/api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
# Comma-separated Discord user IDs allowed to sign in (exactly two people).
ALLOWED_DISCORD_IDS=111111111111111111,222222222222222222
# Secret used to sign the session JWT (min 32 chars). e.g. `openssl rand -hex 32`.
# NEVER commit the real production value.
SESSION_JWT_SECRET=dev-only-session-secret-change-me-0123456789
# Base URL of the Angular dashboard. Production: '/' (same origin). Dev: the dev server.
FRONTEND_BASE_URL=http://localhost:4200
# Allowed browser origin for CORS with credentials. Dev only; leave unset in production.
CORS_ORIGIN=http://localhost:4200
